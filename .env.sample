# URL RTSP complète de la caméra
RTSP_URL=rtsp://LOGIN:PASSWORD@192.168.X.XXX:554/H265/ch1/main/av_stream

# Options audio
OUTPUT_DIR=audios
OUTPUT_PATTERN=rtsp_audio_%Y-%m-%d_%H-%M-%S.wav
AUDIO_SAMPLE_RATE=16000
AUDIO_CHANNELS=1

# tcp (recommandé) ou udp
RTSP_TRANSPORT=tcp

# Durée de chaque segment audio (secondes)
SEGMENT_SECONDS=60

# Suppression des WAV plus anciens que N jours
RETENTION_DAYS=7

# Temps d'attente avant reconnexion après coupure (secondes)
RECONNECT_DELAY_SECONDS=5

# Timeout lecture ffmpeg en microsecondes (utilisé seulement si supporté)
FFMPEG_RW_TIMEOUT_US=15000000
